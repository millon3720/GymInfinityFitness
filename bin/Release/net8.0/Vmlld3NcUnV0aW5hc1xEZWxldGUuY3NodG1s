@model Tesina.Models.Rutina

@{
    ViewData["Title"] = "Eliminar Rutina";
}
<div class="container mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-danger text-center mb-3">
             Confirmación de Eliminación
        </h4>

        <div class="card shadow rounded p-4">
            <h5 class="text-primary text-center mb-4"><i class="bi-clipboard-check"></i> Detalles de la Rutina</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-bold">Nombre:</label>
                    <div class="text-muted">@Model.Nombre</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha de Creación:</label>
                    <div class="text-muted">@Model.FechaCreacion.ToString("dd-MM-yyyy")</div>
                </div>
                <div class="col-12">
                    <label class="fw-bold">Descripción:</label>
                    <div class="text-muted">@Model.Descripcion</div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="mt-4 text-center">
            <input type="hidden" asp-for="IdRutina" />
            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                <button type="submit" class="btn btn-danger btn-lg shadow-sm"
                        onclick="return confirm('Esta acción eliminará permanentemente la rutina. ¿Deseas continuar?')">
                    <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                    <i class="bi bi-arrow-left-circle"></i> Volver al Listado
                </a>
            </div>
        </form>
    </div>
</div>
