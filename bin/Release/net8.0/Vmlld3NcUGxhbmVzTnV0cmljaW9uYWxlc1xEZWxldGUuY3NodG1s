@model Tesina.Models.PlanesNutricionales
@{
    ViewData["Title"] = "Eliminar Plan Nutricional";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-danger text-center mb-3">
            <i class="bi bi-clipboard-x"></i> Confirmación de Eliminación
        </h4>
        <div class="card shadow rounded p-4">
            <h5 class="text-primary text-center mb-4">Detalles del Plan Nutricional</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-bold">Cliente:</label>
                    <div class="text-muted">@Model.Usuario?.NombreCompleto</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha de Asignación:</label>
                    <div class="text-muted">@Model.FechaAsignacion.ToString("dd-MM-yyyy")</div>
                </div>
                <div class="col-12">
                    <label class="fw-bold">Descripción:</label>
                    <div class="text-muted">@Model.Descripcion</div>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdPlan" />
                <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger btn-lg shadow-sm"
                            onclick="return confirm('Esta acción eliminará permanentemente el plan nutricional. ¿Deseas continuar?')">
                        <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                    </button>
                    <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                        <i class="bi bi-arrow-left-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
