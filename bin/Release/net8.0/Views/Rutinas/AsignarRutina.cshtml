@model AsignarRutinaViewModel
<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4"><i class="bi-clipboard-check"></i> Asignar Rutina al Cliente</h4>
        <div class="card shadow rounded p-4">

            <form asp-action="GuardarAsignar" method="post">
                <input type="hidden" asp-for="IdUsuario" />

                <div class="mb-3">
                    <label>Fecha de Asignación</label>
                    <input asp-for="FechaAsignacion" class="form-control" type="date" />
                </div>

                <div class="mb-3">
                    <label>Observaciones</label>
                    <textarea asp-for="Observaciones" class="form-control"></textarea>
                </div>

                <h4 class ="text-primary text-center mb-4"><i class="bi-clipboard-check"></i>Seleccione una Rutina</h4>
                @if (Model.RutinasDisponibles.Any())
                {
                    <div class="table-responsive d-none d-md-block">
                        <table class="table table-bordered table-hover table-striped">
                            <thead class="table-primary text-center">
                                <tr>
                                    <th>Seleccionar</th>
                                    <th>Nombre</th>
                                    <th>Descripción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.RutinasDisponibles.Count; i++)
                                {
                                    <tr class="text-center">
                                        <td>
                                            <input type="radio" asp-for="RutinaSeleccionada" value="@Model.RutinasDisponibles[i].IdRutina" />
                                        </td>
                                        <td>@Model.RutinasDisponibles[i].Nombre</td>
                                        <td>@Model.RutinasDisponibles[i].Descripcion</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="d-block d-md-none">
                        @foreach (var item in Model.RutinasDisponibles)
                        {
                            <div class="card card-rutina mb-3 shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title text-primary nombre">@item.Nombre</h5>
                                    <p class="mb-1 descripcion"><strong>Descripción:</strong> @item.Descripcion</p>
                                    <td>
                                        <label>Seleccionar</label>
                                        <input type="radio" asp-for="RutinaSeleccionada" value="@item.IdRutina" />
                                    </td>

                                </div>
                            </div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Details" asp-route-id="@Model.IdUsuario" asp-controller="Usuarios" class="btn btn-secondary shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Volver a la lista
                        </a>
                        <button type="submit" class="btn btn-success shadow-sm">
                            <i class="bi bi-check-circle"></i> Guardar Asignación
                        </button>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning text-center mt-5">
                        <i class="bi bi-exclamation-circle"></i> No hay rutinas registradas.
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@if (TempData["Alerta"] != null)
{
    <div class="toast-container position-fixed top-0 start-50 translate-middle-x mt-5 p-3" style="z-index: 1055;">
        <div id="liveToast" class="toast bg-danger text-white border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                     @TempData["Alerta"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener('load', function () {
            var toastEl = document.getElementById('liveToast');
            if (toastEl) {
                var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            }
        });
    </script>
}
