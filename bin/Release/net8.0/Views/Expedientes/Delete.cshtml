@model Tesina.Models.Expediente

@{
    ViewData["Title"] = "Eliminar Registro de Medidas";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-danger text-center mb-3">
            <i class="bi bi-person-x-fill"></i> Confirmación de Eliminación
        </h4>
        <div class="card shadow rounded p-4">
            <h5 class="text-primary text-center mb-4">Detalles del Registro de Medidas</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-bold">Cédula Cliente:</label>
                    <div class="text-muted">@Model.Usuario.Cedula</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha Registro:</label>
                    <div class="text-muted">@Model.FechaRegistro.ToString("dd-MM-yyyy")</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Peso (Kg):</label>
                    <div class="text-muted">@Model.PesoKg</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Altura (cm):</label>
                    <div class="text-muted">@Model.AlturaCm</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">IMC:</label>
                    <div class="text-muted">@Model.IMC</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Grasa Corporal (%):</label>
                    <div class="text-muted">@Model.PorcentajeGrasa</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Masa Muscular (%):</label>
                    <div class="text-muted">@Model.PorcentajeMuscular</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Medida Pecho:</label>
                    <div class="text-muted">@Model.MedidaPecho</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Medida Espalda:</label>
                    <div class="text-muted">@Model.MedidaEspalda</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Medida Cintura:</label>
                    <div class="text-muted">@Model.MedidaCintura</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Medida Cadera:</label>
                    <div class="text-muted">@Model.MedidaCadera</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Bíceps Derecho:</label>
                    <div class="text-muted">@Model.BicepDerecho</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Bíceps Izquierdo:</label>
                    <div class="text-muted">@Model.BicepIzquierdo</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Pierna Derecha:</label>
                    <div class="text-muted">@Model.PiernaDerecha</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Pierna Izquierda:</label>
                    <div class="text-muted">@Model.PiernaIzquierda</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Pantorrilla Derecha:</label>
                    <div class="text-muted">@Model.PantorrillaDerecha</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Pantorrilla Izquierda:</label>
                    <div class="text-muted">@Model.PantorrillaIzquierda</div>
                </div>
                <div class="col-12">
                    <label class="fw-bold">Observaciones:</label>
                    <div class="text-muted">@Model.Observaciones</div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4 text-center">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdExpediente" />
            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                <button type="submit" class="btn btn-danger btn-lg shadow-sm"
                        onclick="return confirm('Esta acción eliminará permanentemente el expediente. ¿Deseas continuar?')">
                    <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                </button>
                <a asp-action="Index" asp-controller="Usuarios" class=" btn btn-secondary btn-lg shadow-sm">
                    <i class="bi bi-arrow-left-circle"></i> Volver a la lista
                </a>
            </div>
        </form>
    </div>
</div>

