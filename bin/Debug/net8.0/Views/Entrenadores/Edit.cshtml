@model Tesina.Models.ClienteDetalle

@{
    ViewData["Title"] = "Modificar Entrenador";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4"><i class="bi bi-people-fill"></i> Modificar Entrenador</h4>
        <div class="card shadow rounded p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Cliente.IdUsuario" />

                <div class="mb-3">

                    <label asp-for="Cliente.Cedula" class="form-label">Cédula</label>
                    <input asp-for="Cliente.Cedula" class="form-control" disabled placeholder="Cédula" />
                    <input asp-for="Cliente.Cedula" class="form-control" hidden placeholder="Cédula" />
                </div>

                <div class="mb-3">
                    <label asp-for="Cliente.NombreCompleto" class="form-label">Nombre Completo</label>
                    <input asp-for="Cliente.NombreCompleto" class="form-control" placeholder="Nombre Completo" />
                    <span asp-validation-for="Cliente.NombreCompleto" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cliente.FechaNacimiento" class="form-label">Fecha De Nacimiento</label>
                        <input asp-for="Cliente.FechaNacimiento" class="form-control" type="date" />
                        <span asp-validation-for="Cliente.FechaNacimiento" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cliente.FechaRegistro" class="form-label">Fecha De Registro</label>
                        <input asp-for="Cliente.FechaRegistro" class="form-control" type="datetime-local" />
                        <span asp-validation-for="Cliente.FechaRegistro" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cliente.Correo" class="form-label">Correo Electrónico</label>
                        <input asp-for="Cliente.Correo" class="form-control" placeholder="Correo Electrónico" />
                        <span asp-validation-for="Cliente.Correo" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cliente.Telefono" class="form-label">Número De Teléfono</label>
                        <input asp-for="Cliente.Telefono" class="form-control" placeholder="Número De Teléfono" />
                        <span asp-validation-for="Cliente.Telefono" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Cliente.Direccion" class="form-label">Dirección</label>
                    <input asp-for="Cliente.Direccion" class="form-control" placeholder="Dirección" />
                    <span asp-validation-for="Cliente.Direccion" class="text-danger"></span>
                </div>

                <input type="hidden" asp-for="Cliente.Rol" value="Entrenador" />
                <div class="mb-3">
                    <input class="form-check-input" asp-for="Cliente.Estado" />
                    <label class="form-check-label" asp-for="Cliente.Estado">Estado (Activo o Inactivo)</label>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="@Model.UsuarioLogin.Contrasena" class="form-label">Modificar Contraseña</label>
                        <input type="password" asp-for="@Model.UsuarioLogin.Contrasena" class="form-control" placeholder="Modificar Contraseña" />
                        <span asp-validation-for="@Model.UsuarioLogin.Contrasena" class="text-danger"></span>
                    </div>
                    
                </div>
                

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary shadow-sm">
                        <i class="bi bi-arrow-left-circle"></i> Volver a la lista
                    </a>
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>

                </div>

            </form>
        </div>
        @if (ViewBag.Alerta != null)
        {
            <div class="toast-container position-fixed top-0 start-50 translate-middle-x mt-5 p-3" style="z-index: 1055;">
                <div id="liveToast" class="toast bg-danger text-white border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Alerta
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>
                    </div>
                </div>
            </div>

            <script>
                window.addEventListener('load', function () {
                    var toastEl = document.getElementById('liveToast');
                    if (toastEl) {
                        var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                        toast.show();
                    }
                });
            </script>
        }
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
