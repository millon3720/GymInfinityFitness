@model Tesina.Models.Lesion
@{
    ViewData["Title"] = "Eliminar Lesión";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-danger text-center mb-3">
            <i class="bi bi-clipboard-x"></i> Confirmación de Eliminación
        </h4>
        <div class="card shadow rounded p-4">
            <h5 class="text-primary text-center mb-4">Detalles de la Lesión</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-bold">Descripción:</label>
                    <div class="text-muted">@Model.Descripcion</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha de Diagnóstico:</label>
                    <div class="text-muted">@Model.FechaDiagnostico.ToString("dd-MM-yyyy")</div>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdLesion" />
                <input type="hidden" asp-for="IdUsuario" />
                <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger btn-lg shadow-sm"
                            onclick="return confirm('Esta acción eliminará permanentemente la lesión. ¿Deseas continuar?')">
                        <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                    </button>
                    @if (User.HasClaim("Rol", "Cliente"))
                    {
                        <a asp-action="LesionesClientes" asp-route-id="@Model.IdUsuario" asp-controller="Lesiones" class="btn btn-secondary btn-lg shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Cancelar
                        </a>
                    }
                    @if (User.HasClaim("Rol", "Entrenador"))
                    {<a asp-action="Details" asp-route-id="@Model.IdUsuario" asp-controller="Usuarios" class="btn btn-secondary btn-lg shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Cancelar
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>
