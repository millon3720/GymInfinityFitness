@model Tesina.Models.Lesion
@{
    ViewData["Title"] = "Editar Lesión";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4">
            <i class="bi bi-clipboard-check"></i> Editar Lesión
        </h4>
        <div class="card shadow rounded p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="IdLesion" />
                <input type="hidden" asp-for="IdUsuario" />

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <input asp-for="Descripcion" class="form-control" placeholder="Descripción de la lesión" />
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaDiagnostico" class="form-label"></label>
                    <input asp-for="FechaDiagnostico" class="form-control" type="date" />
                    <span asp-validation-for="FechaDiagnostico" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    @if (User.HasClaim("Rol", "Cliente"))
                    {
                        <a asp-action="LesionesCliente" asp-route-id="@Model.IdUsuario" asp-controller="Lesiones" class="btn btn-secondary shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Volver a la Lista
                    </a>}
                    @if (User.HasClaim("Rol", "Entrenador"))
                    {
                        <a asp-action="Details" asp-route-id="@Model.IdUsuario" asp-controller="Usuarios" class="btn btn-secondary shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Volver a la Lista
                        </a>
                    }
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
