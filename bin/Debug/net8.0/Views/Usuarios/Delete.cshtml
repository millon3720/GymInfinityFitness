@model Tesina.Models.Usuarios

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <h2 class="text-center text-danger mb-4">
                ¿Estás seguro de que deseas eliminar este Cliente?
            </h2>

            <div class="card shadow rounded p-4">
                <div class="card-body">
                    <h4 class="mb-4 text-center text-primary">Detalles del Cliente</h4>
                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Cédula:</dt>
                        <dd class="col-sm-8 text-muted">@Html.DisplayFor(model => model.Cedula)</dd>

                        <dt class="col-sm-4 fw-bold">Nombre Completo:</dt>
                        <dd class="col-sm-8 text-muted">@Html.DisplayFor(model => model.NombreCompleto)</dd>

                        <dt class="col-sm-4 fw-bold">Fecha de Nacimiento:</dt>
                        <dd class="col-sm-8 text-muted">
                            @Convert.ToDateTime(Model.FechaNacimiento).ToString("dd-MM-yyyy")
                        </dd>

                        <dt class="col-sm-4 fw-bold">Correo:</dt>
                        <dd class="col-sm-8 text-muted">@Html.DisplayFor(model => model.Correo)</dd>

                        <dt class="col-sm-4 fw-bold">Teléfono:</dt>
                        <dd class="col-sm-8 text-muted">@Html.DisplayFor(model => model.Telefono)</dd>

                        <dt class="col-sm-4 fw-bold">Dirección:</dt>
                        <dd class="col-sm-8 text-muted">@Html.DisplayFor(model => model.Direccion)</dd>

                        <dt class="col-sm-4 fw-bold">Fecha de Registro:</dt>
                        <dd class="col-sm-8 text-muted">
                            @Convert.ToDateTime(Model.FechaRegistro).ToString("dd-MM-yyyy HH:mm")
                        </dd>

                        <dt class="col-sm-4 fw-bold">Estado:</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.Estado ? "bg-success" : "bg-danger")">
                                @(Model.Estado ? "Activo" : "Inactivo")
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdUsuario" />
                <button type="submit" class="btn btn-danger btn-lg me-2 shadow-sm"
                        onclick="return confirm('¿Estás seguro de que deseas eliminar este Cliente?')">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                    <i class="bi bi-x-circle"></i> Cancelar
                </a>
            </form>

        </div>
    </div>
</div>
