            </th>
            <th>
                @Html.DisplayNameFor(model => model.MedidaPecho)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MedidaEspalda)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MedidaCintura)
