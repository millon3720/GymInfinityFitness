                    <a asp-action="Details" asp-route-id="@item.IdExpediente">Ver</a>
                    <a asp-action="Edit" asp-route-id="@item.IdExpediente">Modificar</a>

                <a asp-action="Delete" asp-route-id="@item.IdExpediente">Delete</a>
