@model Tesina.Models.RutinaCreateViewModel
@{
    ViewData["Title"] = "Crear Rutina";
}
<h4>Crear Rutina</h4>
<hr />
<div class="card shadow rounded p-4">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Rutina.Nombre" class="form-label">Nombre de la Rutina</label>
            <input asp-for="Rutina.Nombre" class="form-control" placeholder="Nombre de la Rutina" />
            <span asp-validation-for="Rutina.Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Rutina.Descripcion" class="form-label">Descripción</label>
            <textarea asp-for="Rutina.Descripcion" class="form-control" rows="3" placeholder="Descripción detallada"></textarea>
            <span asp-validation-for="Rutina.Descripcion" class="text-danger"></span>
        </div>

        <hr />
        <h5 class="text-primary mb-3">Ejercicios de la Rutina</h5>
        <div id="ejerciciosContainer">
            <!-- Aquí se añadirán dinámicamente los ejercicios -->
        </div>

        <button type="button" class="btn btn-success mt-2" onclick="agregarEjercicio()"><i class="bi bi-plus-circle"></i> Agregar Ejercicio</button>

        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left-circle"></i> Volver a la lista</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Guardar Rutina</button>
        </div>
    </form>
</div>


@section Scripts {
    <script>
        let index = 0;

        function agregarEjercicio() {
            const container = document.getElementById("ejerciciosContainer");

            const div = document.createElement("div");
            div.classList.add("border", "rounded", "p-3", "mb-3", "bg-light", "ejercicio-item");

            div.innerHTML = `
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Ejercicio</label>
                        <select name="Ejercicios[${index}].IdEjercicio" class="form-select">
                            @foreach (var ej in ViewBag.Ejercicios as SelectList)
                            {
                                    <option value="@ej.Value">@ej.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Series</label>
                        <input type="number" name="Ejercicios[${index}].Series" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Repeticiones</label>
                        <input type="number" name="Ejercicios[${index}].Repeticiones" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Descanso (seg)</label>
                        <input type="number" name="Ejercicios[${index}].DescansoSegundos" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Día</label>
                        <select name="Ejercicios[${index}].DiaSemana" class="form-select">
                            <option value="">Seleccione un día</option>
                            <option value="Lunes">Lunes</option>
                            <option value="Martes">Martes</option>
                            <option value="Miércoles">Miércoles</option>
                            <option value="Jueves">Jueves</option>
                            <option value="Viernes">Viernes</option>
                            <option value="Sábado">Sábado</option>
                            <option value="Domingo">Domingo</option>
                        </select>
                    </div>
                    <div class="col-12 text-end">
                        <button type="button" class="btn btn-danger btn-sm mt-2" onclick="this.closest('.ejercicio-item').remove()">Eliminar</button>
                    </div>
                </div>
            `;

            container.appendChild(div);
            index++;
        }
    </script>
}

