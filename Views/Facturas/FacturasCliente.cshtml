@model IEnumerable<Tesina.Models.Facturas>
@{
    ViewData["Title"] = "Mis Facturas";
}
<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4"><i class="bi bi-receipt-cutoff"></i> Mis Facturas</h4>
        <div class="card shadow rounded p-4">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover table-striped mb-0">
                        <thead class="table-primary text-center">
                            <tr>
                                <th>Fecha De Creación</th>
                                <th>Monto Total</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>


                            @foreach (var item in Model)
                            {
                                <tr class="text-center">
                                    <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>₡@item.Total.ToString("N2")</td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@item.IdFactura" title="Detalles">
                                                <i class="bi bi-info-circle"></i> Ver
                                            </a>

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center mt-5">
                    <i class="bi bi-exclamation-circle"></i> No hay facturas registradas.
                </div>
            }
        </div>
    </div>
</div>
