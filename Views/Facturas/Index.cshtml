@model IEnumerable<Tesina.Models.Facturas>

@{
    ViewData["Title"] = "Listado de Facturas";
}

<div class="container-fluid mt-4">
    <h4 class="text-primary text-center mb-4">Listado de Facturas</h4>

    <div class="d-flex justify-content-end mb-3">
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Nueva Factura
        </a>
    </div>

    <div class="card shadow rounded">
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped mb-0">
                <thead class="table-primary text-center">
                    <tr>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No hay facturas registradas.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="text-center">
                                <td>@item.Usuario?.NombreCompleto</td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>₡@item.Total.ToString("N2")</td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@item.IdFactura" title="Detalles">
                                            <i class="bi bi-info-circle"></i> Ver
                                        </a>
                                        <a class="btn btn-sm btn-info" asp-action="Edit" asp-route-id="@item.IdFactura" title="Editar">

                                            <i class="bi bi-pencil-square"></i> Modificar
                                        </a>

                                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.IdFactura">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </a>
                                    </div>
                                </td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
