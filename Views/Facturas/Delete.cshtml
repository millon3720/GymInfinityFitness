@model Tesina.Models.Facturas

@{
    ViewData["Title"] = "Eliminar Factura";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <h2 class="text-center text-danger mb-4">
                ¿Estás seguro de que deseas eliminar esta Factura?
            </h2>

            <div class="card shadow rounded p-4">
                <div class="card-body">
                    <h4 class="mb-4 text-center text-primary">Detalles de la Factura</h4>
                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Cliente:</dt>
                        <dd class="col-sm-8 text-muted">@Model.Usuario?.NombreCompleto</dd>

                        <dt class="col-sm-4 fw-bold">Fecha:</dt>
                        <dd class="col-sm-8 text-muted">@Model.Fecha.ToString("dd-MM-yyyy")</dd>

                        <dt class="col-sm-4 fw-bold">Total:</dt>
                        <dd class="col-sm-8 text-muted">₡@Model.Total.ToString("N2")</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdFactura" />
                <button type="submit" class="btn btn-danger btn-lg me-2 shadow-sm"
                        onclick="return confirm('¿Estás seguro de que deseas eliminar esta Factura?')">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                    <i class="bi bi-x-circle"></i> Cancelar
                </a>
            </form>

        </div>
    </div>
</div>
