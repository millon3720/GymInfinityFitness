@model UsuarioLogin

<div class="container d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="max-width: 400px; width: 100%;">
        <div class="text-center mb-4">
            <h3>Recuperar contraseña</h3>
            <p class="text-muted">Ingresá tu correo para recibir una nueva contraseña temporal.</p>
        </div>

        <form asp-action="RecuperarContrasena" method="post">
            <div class="mb-3">
                <label asp-for="Usuario" class="form-label">Correo electrónico</label>
                <input asp-for="Usuario" class="form-control" placeholder="ejemplo@correo.com" required />
                <span asp-validation-for="Usuario" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Enviar contraseña</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-controller="Login" asp-action="Login">Volver al inicio de sesión</a>
        </div>
    </div>
</div>
