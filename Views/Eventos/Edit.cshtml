@model Eventos
@{
    ViewData["Title"] = "Editar Evento";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4">
            <i class="bi bi-calendar-event"></i> Editar Evento
        </h4>
        <div class="card shadow rounded p-4">
            <form asp-action="Edit" enctype="multipart/form-data">
                <input type="hidden" asp-for="IdEvento" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Nombre del evento" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripción detallada"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaEvento" class="form-label"></label>
                    <input asp-for="FechaEvento" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaEvento" class="text-danger"></span>
                </div>

                @if (Model.Imagen != null)
                {
                    <div class="mb-3">
                        <label class="form-label">Imagen actual:</label><br />
                        <img src="@Url.Action("VerImagen", "Eventos", new { id = Model.IdEvento })" width="150" class="rounded shadow-sm" />
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Reemplazar imagen:</label>
                    <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary shadow-sm">
                        <i class="bi bi-arrow-left-circle"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
