@model Eventos
@{
    ViewData["Title"] = "Eliminar Evento";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-danger text-center mb-3">
            <i class="bi bi-calendar-x-fill"></i> Confirmación de Eliminación
        </h4>
        <div class="card shadow rounded p-4">
            <h5 class="text-primary text-center mb-4">Detalles del Evento</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-bold">Nombre:</label>
                    <div class="text-muted">@Model.Nombre</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha:</label>
                    <div class="text-muted">@Model.FechaEvento.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="col-12">
                    <label class="fw-bold">Imagen:</label><br />
                    @if (Model.Imagen != null)
                    {
                        <img src="@Url.Action("VerImagen", "Eventos", new { id = Model.IdEvento })"
                             class="img-fluid rounded shadow-sm"
                             style="max-width: 200px;" />
                    }
                    else
                    {
                        <span class="text-muted">Sin imagen disponible</span>
                    }
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdEvento" />
                <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger btn-lg shadow-sm"
                            onclick="return confirm('Esta acción eliminará permanentemente el evento. ¿Deseas continuar?')">
                        <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                    </button>
                    <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                        <i class="bi bi-arrow-left-circle"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
