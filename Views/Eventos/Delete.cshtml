@model Eventos

@{
    ViewData["Title"] = "Eliminar Evento";
}

<div class="container-fluid mt-4">
    <h4 class="text-danger text-center mb-4">¿Estás seguro de eliminar este evento?</h4>
    <div class="card shadow rounded p-4 mb-4">
        <dl class="row">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.FechaEvento.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Imagen</dt>
            <dd class="col-sm-9">
                @if (Model.Imagen != null)
                {
                    <img src="@Url.Action("VerImagen", "Eventos", new { id = Model.IdEvento })" width="120" class="rounded shadow-sm" />
                }
                else
                {
                    <span class="text-muted">Sin imagen</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="IdEvento" />
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary shadow-sm">
                    <i class="bi bi-arrow-left-circle"></i> Cancelar
                </a>
                <button type="submit" class="btn btn-danger shadow-sm">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        </form>
    </div>
</div>
