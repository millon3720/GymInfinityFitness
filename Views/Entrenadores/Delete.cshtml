@model Tesina.Models.Usuarios

@{
    ViewData["Title"] = "Eliminar Entrenador";
}
<div class="container mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-danger text-center mb-3">
            <i class="bi bi-person-x-fill"></i> Confirmación de Eliminación
        </h4>
        <div class="card shadow rounded p-4">
            <h5 class="text-primary text-center mb-4">Detalles del Entrenador</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-bold">Cédula:</label>
                    <div class="text-muted">@Model.Cedula</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Nombre Completo:</label>
                    <div class="text-muted">@Model.NombreCompleto</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha De Nacimiento:</label>
                    <div class="text-muted">@Model.FechaNacimiento.ToString("dd-MM-yyyy")</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Fecha De Registro:</label>
                    <div class="text-muted">@Model.FechaRegistro.ToString("dd-MM-yyyy HH:mm")</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Correo Electrónico:</label>
                    <div class="text-muted">@Model.Correo</div>
                </div>
                <div class="col-md-6">
                    <label class="fw-bold">Teléfono:</label>
                    <div class="text-muted">@Model.Telefono</div>
                </div>
                <div class="col-12">
                    <label class="fw-bold">Dirección:</label>
                    <div class="text-muted">@Model.Direccion</div>
                </div>
                <div class="col-12">
                    <label class="fw-bold">Estado:</label>
                    <div>
                        <span class="badge @(Model.Estado ? "bg-success" : "bg-danger")">
                            @(Model.Estado ? "Activo" : "Inactivo")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="mt-4 text-center">
            <input type="hidden" asp-for="IdUsuario" />
            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
                <button type="submit" class="btn btn-danger btn-lg shadow-sm"
                        onclick="return confirm('Esta acción eliminará permanentemente al entrenador. ¿Deseas continuar?')">
                    <i class="bi bi-trash3-fill"></i> Confirmar Eliminación
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                    <i class="bi bi-arrow-left-circle"></i> Volver al Listado
                </a>
            </div>
        </form>
    </div>
</div>
