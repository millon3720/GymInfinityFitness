@model Tesina.Models.Usuarios

@{
    ViewData["Title"] = "Details";
}
<div class="container">

    <div class="container">
        <h2 class="text-center">Detalles del Entrenador</h2>

        <div class="row">
            <div class="col-md-3 mb-3">
                <strong>Código de Usuario:</strong><br />
                @Model.IdUsuario
            </div>
            <div class="col-md-3 mb-3">
                <strong>Cédula:</strong><br />
                @Model.Cedula
            </div>
            <div class="col-md-3 mb-3">
                <strong>Nombre Completo:</strong><br />
                @Model.NombreCompleto
            </div>
            <div class="col-md-3 mb-3">
                <strong>Fecha Nacimiento:</strong><br />
                @Model.FechaNacimiento.ToString("dd-MM-yyyy")
            </div>

            <div class="col-md-3 mb-3">
                <strong>Correo:</strong><br />
                @Model.Correo
            </div>
            <div class="col-md-3 mb-3">
                <strong>Teléfono:</strong><br />
                @Model.Telefono
            </div>
            <div class="col-md-3 mb-3">
                <strong>Dirección:</strong><br />
                @Model.Direccion
            </div>
            <div class="col-md-3 mb-3">
                <strong>Fecha de Registro:</strong><br />
                @Model.FechaRegistro.ToString()
            </div>

            <div class="col-md-3 mb-3">
                <strong>Estado:</strong><br />
                @(Model.Estado ? "Activo" : "Inactivo")
            </div>
            <div class="d-flex justify-content-between mt-4">
                <a class="btn btn-sm btn-info me-1" asp-action="Edit" asp-route-id="@Model.IdUsuario" title="Editar">
                    Editar<i class="bi bi-pencil-square"></i>
                </a>                <a asp-action="Index" class="btn btn-link">Volver a la lista</a>
            </div>
        </div>
    </div>
</div>