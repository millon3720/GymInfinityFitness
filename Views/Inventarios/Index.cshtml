@model IEnumerable<Tesina.Models.ProductoInventarioViewModel>
@{
    ViewData["Title"] = "Inventario de Productos y Servicios";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4">
            <i class="bi bi-box-seam"></i> Inventario de Productos y Servicios
        </h4>
        <div class="card shadow rounded p-4">

            <!-- Filtro y botón -->
            <div class="card p-3 mb-4 shadow-sm border-0 bg-light">
                <div class="row align-items-center mb-3">
                    <div class="col-md-6 col-sm-12">
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-primary text-white"><i class="bi bi-search"></i></span>
                            <input type="text" id="filtroInventario" class="form-control" placeholder="Buscar por nombre o tipo..." />
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-12 text-md-end mt-2 mt-md-0">
                        <a asp-action="Create" class="btn btn-success shadow-sm">
                            <i class="bi bi-plus-circle"></i> Registrar nuevo
                        </a>
                    </div>
                </div>
            </div>

            <!-- Mensaje sin resultados -->
            <div id="sinResultados" class="alert alert-warning text-center d-none">
                <i class="bi bi-exclamation-circle"></i> No se encontraron productos que coincidan.
            </div>

            @if (Model.Any())
            {
                <!-- Vista escritorio -->
                <div class="table-responsive d-none d-md-block">
                    <table id="tablaInventario" class="table table-bordered table-hover table-striped">
                        <thead class="table-primary text-center">
                            <tr>
                                <th class="nombre">Nombre</th>
                                <th class="tipo">Tipo</th>
                                <th>Precio</th>
                                <th>Cantidad Disponible o duración</th>
                                <th>Punto de Reorden</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var requiereReorden = item.Inventario.CantidadDisponible <= item.Inventario.PuntoDeReorden;
                                <tr class="text-center">
                                    <td class="nombre">@item.Producto.Nombre</td>
                                    <td class="tipo">@item.Producto.Tipo</td>
                                    <td>@item.Producto.Precio.ToString("C")</td>
                                    @if (item.Producto.Tipo == "Membresía")
                                    {
                                        <td>@item.Inventario.CantidadDisponible Dias</td>
                                    }
                                    else
                                    {
                                        <td>@item.Inventario.CantidadDisponible Unidades</td>
                                    }
                                    <td>@item.Inventario.PuntoDeReorden</td>
                                    <td>
                                        <span class="badge @(requiereReorden && item.Producto.Tipo.ToLower() != "servicio" ? "bg-danger" : "bg-success")">
                                            @(requiereReorden && item.Producto.Tipo.ToLower() != "servicio" ? "Reabastecer" : "Stock OK")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@item.Producto.IdProductoServicio"><i class="bi bi-info-circle"></i> Detalles</a>
                                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Producto.IdProductoServicio"><i class="bi bi-pencil-square"></i> Modificar</a>
                                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Producto.IdProductoServicio"><i class="bi bi-trash"></i> Eliminar</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Vista móvil -->
                <div class="d-block d-md-none">
                    @foreach (var item in Model)
                    {
                        var requiereReorden = item.Inventario.CantidadDisponible <= item.Inventario.PuntoDeReorden;
                        <div class="card card-inventario mb-3 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title text-primary nombre">@item.Producto.Nombre</h5>
                                <p class="mb-1 tipo"><strong>Tipo:</strong> @item.Producto.Tipo</p>
                                <p class="mb-1"><strong>Precio:</strong> @item.Producto.Precio.ToString("C")</p>
                                @if (item.Producto.Tipo == "Producto")
                                {
                                    <p class="mb-1"><strong>Cantidad Disponible:</strong> @item.Inventario.CantidadDisponible</p>
                                    <p class="mb-1"><strong>Punto de Reorden:</strong> @item.Inventario.PuntoDeReorden</p>
                                    <p class="mb-3">
                                        <strong>Estado:</strong>
                                        <span class="badge @(requiereReorden ? "bg-danger" : "bg-success")">
                                            @(requiereReorden ? "Reabastecer" : "Stock OK")
                                        </span>
                                    </p>
                                }
                                @if (item.Producto.Tipo == "Membresía")
                                {
                                    <p class="mb-1"><strong>Duración (en días):</strong> @item.Inventario.CantidadDisponible</p>
                                    
                                }
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@item.Producto.IdProductoServicio"><i class="bi bi-info-circle"></i> Detalles</a>
                                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Producto.IdProductoServicio"><i class="bi bi-pencil-square"></i> Modificar</a>
                                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Producto.IdProductoServicio"><i class="bi bi-trash"></i> Eliminar</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center mt-5">
                    <i class="bi bi-exclamation-circle"></i> No hay productos registrados.
                </div>
            }
        </div>
        @if (TempData["Alerta"] != null)
        {
            <div class="toast-container position-fixed top-0 start-50 translate-middle-x mt-5 p-3" style="z-index: 1055;">
                <div id="liveToast" class="toast bg-success text-white border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Alerta"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>
                    </div>
                </div>
            </div>

            <script>
                window.addEventListener('load', function () {
                    var toastEl = document.getElementById('liveToast');
                    if (toastEl) {
                        var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                        toast.show();
                    }
                });
            </script>
        }
    </div>
</div>

<script>
    document.getElementById("filtroInventario").addEventListener("input", function () {
        const filtro = this.value.toLowerCase();

        const filas = document.querySelectorAll("#tablaInventario tbody tr");
        let coincidenciasTabla = 0;

        filas.forEach(fila => {
            const nombre = fila.querySelector(".nombre").textContent.toLowerCase();
            const tipo = fila.querySelector(".tipo").textContent.toLowerCase();
            const coincide = nombre.includes(filtro) || tipo.includes(filtro);
            fila.style.display = coincide ? "" : "none";
            if (coincide) coincidenciasTabla++;
        });

        const cards = document.querySelectorAll(".card-inventario");
        let coincidenciasCards = 0;

        cards.forEach(card => {
            const nombre = card.querySelector(".nombre").textContent.toLowerCase();
            const tipo = card.querySelector(".tipo").textContent.toLowerCase();
            const coincide = nombre.includes(filtro) || tipo.includes(filtro);
            card.style.display = coincide ? "" : "none";
            if (coincide) coincidenciasCards++;
        });

        const totalCoincidencias = coincidenciasTabla + coincidenciasCards;
        const mensaje = document.getElementById("sinResultados");
        if (mensaje) {
            mensaje.classList.toggle("d-none", totalCoincidencias > 0);
        }
    });
</script>
