@model ProductoInventarioViewModel

@{
    ViewData["Title"] = "Editar Producto o Servicio";
}

<div class="container-fluid mt-4">
    <h4 class="text-primary text-center mb-4">Editar Producto o Servicio</h4>
    <div class="card shadow rounded p-4 mb-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Producto.IdProductoServicio" />
            <input type="hidden" asp-for="Inventario.IdInventario" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h5 class="text-secondary mb-3">Información del Producto o Servicio</h5>

            <div class="mb-3">
                <label asp-for="Producto.Nombre" class="form-label"></label>
                <input asp-for="Producto.Nombre" class="form-control" />
                <span asp-validation-for="Producto.Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Producto.Descripcion" class="form-label"></label>
                <textarea asp-for="Producto.Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Producto.Descripcion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Producto.Tipo" class="form-label"></label>
                <input asp-for="Producto.Tipo" class="form-control" />
                <span asp-validation-for="Producto.Tipo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Producto.Precio" class="form-label"></label>
                <input type="number" step="0.01" asp-for="Producto.Precio" class="form-control" />
                <span asp-validation-for="Producto.Precio" class="text-danger"></span>
            </div>

            <h5 class="text-secondary mt-4 mb-3">Inventario</h5>

            <div class="mb-3">
                <label asp-for="Inventario.CantidadDisponible" class="form-label"></label>
                <input type="number" step="0.01" asp-for="Inventario.CantidadDisponible" class="form-control" />
                <span asp-validation-for="Inventario.CantidadDisponible" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Inventario.PuntoDeReorden" class="form-label"></label>
                <input type="number" step="0.01" asp-for="Inventario.PuntoDeReorden" class="form-control" />
                <span asp-validation-for="Inventario.PuntoDeReorden" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary shadow-sm">
                    <i class="bi bi-arrow-left-circle"></i> Cancelar
                </a>
                <button type="submit" class="btn btn-primary shadow-sm">
                    <i class="bi bi-save"></i> Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
