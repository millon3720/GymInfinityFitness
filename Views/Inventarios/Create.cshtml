@model Tesina.Models.ProductoInventarioViewModel
@{
    ViewData["Title"] = "Registrar Producto o Servicio";
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4">
            <i class="bi bi-box-seam"></i> Registrar Producto o Servicio
        </h4>
        <div class="card shadow rounded p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <h5 class="text-secondary mb-3">Información del Producto o Servicio</h5>

                <div class="mb-3">
                    <label asp-for="Producto.Nombre" class="form-label"></label>
                    <input asp-for="Producto.Nombre" class="form-control" placeholder="Nombre del producto o servicio" />
                    <span asp-validation-for="Producto.Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Producto.Descripcion" class="form-label"></label>
                    <textarea asp-for="Producto.Descripcion" class="form-control" rows="3" placeholder="Descripción detallada"></textarea>
                    <span asp-validation-for="Producto.Descripcion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="tipoProducto" class="form-label">Tipo</label>
                    <select id="tipoProducto" name="Producto.Tipo" class="form-select">
                        <option value="">-- Seleccione el tipo --</option>
                        <option value="Producto">Producto</option>
                        <option value="Servicio">Servicio</option>
                        <option value="Membresía">Membresía</option>
                    </select>
                </div>


                <div class="mb-3">
                    <label asp-for="Producto.Precio" class="form-label"></label>
                    <input type="number" step="0.01" asp-for="Producto.Precio" class="form-control" placeholder="Precio en colones" />
                    <span asp-validation-for="Producto.Precio" class="text-danger"></span>
                </div>

                <div class="mb-3" id="grupoCantidad">
                    <label id="labelCantidad" asp-for="Inventario.CantidadDisponible" class="form-label">Cantidad disponible</label>
                    <input type="number" step="0.01" asp-for="Inventario.CantidadDisponible" class="form-control" placeholder="Cantidad disponible" />
                    <span asp-validation-for="Inventario.CantidadDisponible" class="text-danger"></span>
                </div>

                <div class="mb-3" id="grupoPuntoReorden">
                    <label asp-for="Inventario.PuntoDeReorden" class="form-label"></label>
                    <input type="number" step="0.01" asp-for="Inventario.PuntoDeReorden" class="form-control" placeholder="Punto de reorden" />
                    <span asp-validation-for="Inventario.PuntoDeReorden" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary shadow-sm">
                        <i class="bi bi-arrow-left-circle"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tipoSelect = document.getElementById("tipoProducto");
        const labelCantidad = document.getElementById("labelCantidad");
        const grupoPuntoReorden = document.getElementById("grupoPuntoReorden");
        const grupoCantidad = document.getElementById("grupoCantidad");

        function actualizarLabel() {
            const tipo = tipoSelect.value;

            if (tipo === "Producto") {
                labelCantidad.textContent = "Cantidad disponible";
            } else if (tipo === "Servicio") {
                labelCantidad.textContent = "Capacidad o disponibilidad";
            } else if (tipo === "Membresía" || tipo === "Mensualidad") {
                labelCantidad.textContent = "Duración (en días)";
            } else {
                labelCantidad.textContent = "Cantidad o duración";
            }
        }

            function actualizarVisibilidad() {
        const tipo = tipoSelect.value;

        if (tipo === "Servicio" || tipo === "Membresía" || tipo === "Mensualidad") {
            grupoPuntoReorden.style.display = "none";
            grupoCantidad.style.display = (tipo === "Servicio") ? "none" : "block"; // solo oculta si es Servicio
        } else {
            grupoPuntoReorden.style.display = "block";
            grupoCantidad.style.display = "block";
        }
    }


        tipoSelect.addEventListener("change", function () {
            actualizarLabel();
            actualizarVisibilidad();
        });

        actualizarLabel();
        actualizarVisibilidad();
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
