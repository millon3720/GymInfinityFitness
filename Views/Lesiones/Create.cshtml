@model Tesina.Models.ClienteDetalle

<h2>Crear Lesiones</h2>
<hr />

<form asp-action="CrearLesiones" method="post">
    <div id="lesionesContainer">
        <!-- Se añadirán dinámicamente los formularios de lesiones -->
    </div>

    <button type="button" class="btn btn-secondary mt-2" onclick="agregarLesion()">Agregar Lesión</button>
    <hr />
    <button type="submit" class="btn btn-primary mt-3">Guardar Todas las Lesiones</button>
</form>

@section Scripts {
    <script>
        let index = 0;

        function agregarLesion() {
            const container = document.getElementById("lesionesContainer");

            const div = document.createElement("div");
            div.classList.add("border", "p-3", "mb-3", "lesion-item");

            div.innerHTML = `
                <div class="row align-items-end">
                    <input type="hidden" name="Lesion[${index}].IdUsuario" value="@Model.Cliente.IdUsuario" />

                    <div class="col-md-4">
                        <label>Descripción</label>
                        <input type="text" name="Lesion[${index}].Descripcion" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label>Fecha Diagnóstico</label>
                        <input type="date" name="Lesion[${index}].FechaDiagnostico" class="form-control" />
                    </div>
                    <div class="col-12 text-end mt-2">
                        <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('.lesion-item').remove()">Eliminar</button>
                    </div>
                </div>
            `;

            container.appendChild(div);
            index++;
        }
    </script>
}
