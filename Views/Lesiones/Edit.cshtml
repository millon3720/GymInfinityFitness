@model Tesina.Models.Lesion

@{
    ViewData["Title"] = "Editar Lesión";
}

<h4>Editar Lesión</h4>
<hr />
<div class="card shadow rounded p-4">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="IdLesion" />
        <input type="hidden" asp-for="IdUsuario" />

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
            <input asp-for="Descripcion" class="form-control" placeholder="Ingrese la descripción de la lesión" />
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FechaDiagnostico" class="form-label fw-bold">Fecha de Diagnóstico</label>
            <input asp-for="FechaDiagnostico" class="form-control" type="date" />
            <span asp-validation-for="FechaDiagnostico" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Details" asp-route-id="IdUsuario" asp-controller="Usuarios" class="btn btn-secondary"><i class="bi bi-arrow-left-circle"></i> Volver a la Lista</a>
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
        </div>
    </form>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
