@model IEnumerable<Tesina.Models.PlanesNutricionales>

@{
    ViewData["Title"] = "Planes Nutricionales";
}

<div class="container mt-5">
    <h2 class="text-center text-primary mb-4">
        <i class="bi bi-journal-medical"></i> Lista de Planes Nutricionales
    </h2>

    <div class="d-flex justify-content-end mb-3">
        <a class="btn btn-success" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Crear Nuevo Plan
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover shadow-sm rounded">
                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Descripción</th>
                        <th>Fecha de Asignación</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Usuario.NombreCompleto</td>
                            <td>@item.Descripcion</td>
                            <td>@item.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-primary me-1" asp-action="Details" asp-route-id="@item.IdPlan" title="Detalles">
                                    <i class="bi bi-info-circle"></i> Ver
                                </a>
                                <a class="btn btn-sm btn-info me-1" asp-action="Edit" asp-route-id="@item.IdPlan" title="Editar">
                                    <i class="bi bi-pencil-square"></i> Modificar
                                </a>
                                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.IdPlan" title="Eliminar">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center mt-5">
            <i class="bi bi-exclamation-circle"></i> No hay planes nutricionales registrados.
        </div>
    }
</div>
