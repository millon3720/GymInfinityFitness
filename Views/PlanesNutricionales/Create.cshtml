@model Tesina.Models.PlanAlimenticioViewModel

@{
    ViewData["Title"] = "Crear Plan Nutricional";
}

<h2>Crear Plan Nutricional</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Plan.IdUsuario" class="form-label"></label>
                <select asp-for="Plan.IdUsuario" class="form-control" asp-items="ViewBag.IdUsuario"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Plan.Descripcion" class="form-label"></label>
                <input asp-for="Plan.Descripcion" class="form-control" />
                <span asp-validation-for="Plan.Descripcion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Plan.FechaAsignacion" class="form-label"></label>
                <input asp-for="Plan.FechaAsignacion" type="date" class="form-control" />
                <span asp-validation-for="Plan.FechaAsignacion" class="text-danger"></span>
            </div>

            <hr />
            <h4>Alimentos del Plan</h4>
            <div id="alimentosContainer">
                <!-- Aquí se agregan dinámicamente los alimentos -->
            </div>

            <button type="button" class="btn btn-secondary mb-3" onclick="agregarAlimento()">Agregar Alimento</button>
            <hr />
            <button type="submit" class="btn btn-primary">Guardar Plan</button>
            <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>

        </form>
    </div>
</div>
@section Scripts {
    <script>
        let index = 0;
        function agregarAlimento() {
            const container = document.getElementById("alimentosContainer");
            const div = document.createElement("div");
            div.classList.add("border", "p-3", "mb-3");

            div.innerHTML = `
                <div class="row">
                    <div class="col-md-2">
                        <label>Día</label>
                        <select name="Alimentos[${index}].DiaSemana" class="form-select">
                            <option value="Lunes">Lunes</option>
                            <option value="Martes">Martes</option>
                            <option value="Miércoles">Miércoles</option>
                            <option value="Jueves">Jueves</option>
                            <option value="Viernes">Viernes</option>
                            <option value="Sábado">Sábado</option>
                            <option value="Domingo">Domingo</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Comida</label>
                        <input type="text" name="Alimentos[${index}].Comida" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Hora Estimada</label>
                        <input type="time" name="Alimentos[${index}].HoraEstimada" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label>Alimento</label>
                        <input type="text" name="Alimentos[${index}].Alimento" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Porciones</label>
                        <input type="text" name="Alimentos[${index}].Porciones" class="form-control" />
                    </div>
                     <div class="col-md-3">
                    <label>Comentarios</label>
                    <input type="text" name="Alimentos[${index}].Comentarios" class="form-control" />
                </div>
                    <div class="col-md-1">
                        <label>&nbsp;</label>
                        <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('div.row').remove()">Eliminar</button>
                    </div>
                </div>
            `;
            container.appendChild(div);
            index++;
        }
    </script>

}
