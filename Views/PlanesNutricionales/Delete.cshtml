@model Tesina.Models.PlanesNutricionales

@{
    ViewData["Title"] = "Eliminar Plan Nutricional";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="text-center text-danger mb-4">¿Estás seguro de que deseas eliminar este plan nutricional?</h2>

            <div class="card shadow-sm rounded-3">
                <div class="card-body">
                    <h4 class="mb-3 text-center">Plan Nutricional</h4>
                    <dl class="row">
                        <dt class="col-sm-4">Usuario</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Usuario.Cedula)</dd>

                        <dt class="col-sm-4">Descripción</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Descripcion)</dd>

                        <dt class="col-sm-4">Fecha de Asignación</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaAsignacion)</dd>                        
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdPlan" />
                <button type="submit" class="btn btn-danger me-2" onclick="return confirm('¿Estás seguro de que deseas eliminar este plan nutricional?')" title="Eliminar">
                    Eliminar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>
