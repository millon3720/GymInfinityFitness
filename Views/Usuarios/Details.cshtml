@model Tesina.Models.ClienteDetalle
@using System.Text.Json

@{
    ViewData["Title"] = "Detalles del Cliente";
}
<div class="container">

    <div class="container">
        <h2 class="text-center">Detalles del Cliente</h2>

        <div class="row">
            <div class="col-md-3 mb-3">
                <strong>Código de Usuario:</strong><br />
                @Model.Cliente.IdUsuario
            </div>
            <div class="col-md-3 mb-3">
                <strong>Cédula:</strong><br />
                @Model.Cliente.Cedula
            </div>
            <div class="col-md-3 mb-3">
                <strong>Nombre Completo:</strong><br />
                @Model.Cliente.NombreCompleto
            </div>
            <div class="col-md-3 mb-3">
                <strong>Fecha Nacimiento:</strong><br />
                @Model.Cliente.FechaNacimiento.ToString("dd-MM-yyyy")
            </div>

            <div class="col-md-3 mb-3">
                <strong>Correo:</strong><br />
                @Model.Cliente.Correo
            </div>
            <div class="col-md-3 mb-3">
                <strong>Teléfono:</strong><br />
                @Model.Cliente.Telefono
            </div>
            <div class="col-md-3 mb-3">
                <strong>Dirección:</strong><br />
                @Model.Cliente.Direccion
            </div>
            <div class="col-md-3 mb-3">
                <strong>Fecha de Registro:</strong><br />
                @Model.Cliente.FechaRegistro.ToString()
            </div>

            <div class="col-md-3 mb-3">
                <strong>Estado:</strong><br />
                @(Model.Cliente.Estado ? "Activo" : "Inactivo")
            </div>
        </div>
    </div>


    <hr />
    @* Graficos Medidas *@
    <div class="accordion" id="accordionGraficos">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingGraficos">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseGraficos" aria-expanded="true" aria-controls="collapseGraficos">
                    Graficas De Las Medidas Corporales
                </button>
            </h2>
            <div id="collapseGraficos" class="accordion-collapse collapse " aria-labelledby="headingGraficos" data-bs-parent="#accordionGraficos">
                <div class="accordion-body">
                    <div class="accordion-body text-end">
                        <a asp-action="Create" asp-route-id="@Model.Cliente.IdUsuario" asp-controller="Expedientes" class="btn btn-primary">
                            Agregar Medida
                        </a>
                    </div>
                    @await Html.PartialAsync("/Views/Expedientes/Graficas.cshtml", Model.Expedientes.ToList())


                </div>
            </div>
        </div>
    </div>

    @* Tabla Medidas *@
    <div class="accordion" id="accordionTablaMedidas">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingTablaMedidas">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseTablaMedidas" aria-expanded="true" aria-controls="collapseTablaMedidas">
                    Tabla De Las Medidas Corporales
                </button>
            </h2>         
            <div id="collapseTablaMedidas" class="accordion-collapse collapse " aria-labelledby="headingTablaMedidas" data-bs-parent="#accordionTablaMedidas">
                <div class="accordion-body">
                    <div class="accordion-body text-end">
                        <a asp-action="Create" asp-route-id="@Model.Cliente.IdUsuario" asp-controller="Expedientes" class="btn btn-primary">
                            Agregar Medida
                        </a>
                    </div>

                    <div class="row">
                        <div class="card shadow p-4 mb-4">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover table-striped">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Peso (Kg)</th>
                                            <th>Altura (cm)</th>
                                            <th>IMC</th>
                                            <th>% Grasa</th>
                                            <th>% Músculo</th>
                                            <th>Pecho</th>
                                            <th>Espalda</th>
                                            <th>Cintura</th>
                                            <th>Cadera</th>
                                            <th>Bícep Der.</th>
                                            <th>Bícep Izq.</th>
                                            <th>Pierna Der.</th>
                                            <th>Pierna Izq.</th>
                                            <th>Pant. Der.</th>
                                            <th>Pant. Izq.</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Expedientes)
                                        {
                                            <tr>
                                                <td>@item.FechaRegistro.ToShortDateString()</td>
                                                <td>@item.PesoKg</td>
                                                <td>@item.AlturaCm</td>
                                                <td>@item.IMC</td>
                                                <td>@item.PorcentajeGrasa</td>
                                                <td>@item.PorcentajeMuscular</td>
                                                <td>@item.MedidaPecho</td>
                                                <td>@item.MedidaEspalda</td>
                                                <td>@item.MedidaCintura</td>
                                                <td>@item.MedidaCadera</td>
                                                <td>@item.BicepDerecho</td>
                                                <td>@item.BicepIzquierdo</td>
                                                <td>@item.PiernaDerecha</td>
                                                <td>@item.PiernaIzquierda</td>
                                                <td>@item.PantorrillaDerecha</td>
                                                <td>@item.PantorrillaIzquierda</td>
                                                <td>
                                                    <a class="btn btn-sm btn-info me-1" asp-action="Edit" asp-controller="Expedientes" asp-route-id="@item.IdExpediente">Editar<i class="bi bi-pencil-square"></i></a>
                                                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-controller="Expedientes" asp-route-id="@item.IdExpediente">Eliminar<i class="bi bi-trash"></i></a>
                                                </td>
                                            </tr>
                                        }
                                        
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Lesiones *@
    <div class="accordion" id="accordionLesiones">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingLesiones">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseLesiones" aria-expanded="true" aria-controls="collapseLesiones">
                    Lesiones
                </button>
            </h2>
            <div id="collapseLesiones" class="accordion-collapse collapse " aria-labelledby="headingLesiones" data-bs-parent="#accordionLesiones">
                <div class="accordion-body">
                    <div class="row">
                        <!-- info aqui -->
                        <div class="accordion-body text-end">
                            <a asp-action="Create" asp-route-id="@Model.Cliente.IdUsuario" asp-controller="Lesiones" class="btn btn-primary">
                                Agregar Lesion
                            </a>
                        </div>
                        <div class="row">
                            @if (Model.Lesion != null && Model.Lesion.Any())
                            {
                                <div class="card shadow p-4 mb-4">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover table-striped">
                                            <thead class="table-dark">
                                                <tr>
                                                    <th>Descripcion</th>
                                                    <th>Fecha de Diagnostico</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.Lesion)
                                                {
                                                    <tr>
                                                        <td>@item.Descripcion</td>
                                                        <td>@item.FechaDiagnostico.ToShortDateString()</td>
                                                        <td>
                                                            <a class="btn btn-sm btn-info me-1" asp-controller="Lesiones" asp-action="Edit" asp-route-id="@item.IdLesion">Editar<i class="bi bi-pencil-square"></i></a> 
                                                            <a class="btn btn-sm btn-danger" asp-controller="Lesiones" asp-action="Delete" asp-route-id="@item.IdLesion">Eliminar<i class="bi bi-trash"></i></a>
                                                        </td>
                                                    </tr>
                                                }

                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No hay Lesiones Registradas.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Rutinas *@
    <div class="accordion" id="accordionRutinas">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingRutinas">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseRutinas" aria-expanded="true" aria-controls="collapseRutinas">
                    Rutinas Asignadas
                </button>
            </h2>
            <div id="collapseRutinas" class="accordion-collapse collapse " aria-labelledby="headingRutinas" data-bs-parent="#accordionRutinas">
                <div class="accordion-body"> 
                    <div class="accordion-body text-end">
                        <a asp-action="AsignarRutina" asp-route-IdUsuario="@Model.Cliente.IdUsuario"
                           asp-controller="Rutinas" class="btn btn-primary">
                            Asignar Rutina
                        </a>                      
                    </div>
                    <div class="row">
                        @if (Model.Rutina!=null)
                        {
                            
                        
                        <!-- info aqui -->
                        <div class="card-body">   
                            
                            @{
                                var diasSemanaOrdenados = new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" };
                                var ejerciciosPorDia = Model.RutinaEjercicios
                                .GroupBy(e => e.DiaSemana)
                                .OrderBy(g => Array.IndexOf(diasSemanaOrdenados, g.Key));
                            }
                            @if (Model.RutinaEjercicios != null && Model.RutinaEjercicios.Any())
                            {
                                @foreach (var dia in ejerciciosPorDia)
                                {
                                    <h5 class="mt-3">@dia.Key</h5>
                                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                                        @foreach (var ejercicio in dia)
                                        {
                                            <div class="col">
                                                <div class="card h-100 shadow-sm">
                                                    <div class="card-body">
                                                        <h6 class="card-title">@ejercicio.Ejercicio.Nombre</h6>
                                                        <p class="card-text">
                                                            <strong>Series:</strong> @ejercicio.Series <br />
                                                            <strong>Repeticiones:</strong> @ejercicio.Repeticiones <br />
                                                            <strong>Descanso:</strong> @ejercicio.DescansoSegundos seg
                                                        </p>
                                                        @if (!string.IsNullOrEmpty(ejercicio.Ejercicio.VideoURL))
                                                        {
                                                            <div class="ratio ratio-16x9">
                                                                <iframe src="@ConvertToEmbed(ejercicio.Ejercicio.VideoURL)"
                                                                        title="@ejercicio.Ejercicio.Nombre"
                                                                        allowfullscreen></iframe>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">Sin video</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No hay ejercicios asignados a esta rutina.</p>
                            }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No hay rutinas asignadas.</p>
                        }
                    </div>
               </div>
            </div>
        </div>
    </div>

    @* Planes Nutricionales *@
    <div class="accordion" id="accordionPlanesNutricionales">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingPlanes">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapsePlanes" aria-expanded="true" aria-controls="collapsePlanes">
                    Planes Nutricionales
                </button>
            </h2>
            <div id="collapsePlanes" class="accordion-collapse collapse " aria-labelledby="headingPlanes" data-bs-parent="#accordionPlanesNutricionales">
                <div class="accordion-body">

                    <div class="accordion-body">
                        <div class="row">
                            <div class="card mt-3">

                                <div class="card-body">
                                    @if (Model.PlanesNutricionales.Any())
                                    {
                                        var plan = Model.PlanesNutricionales.First();
                                        <div class="mb-3">
                                            <h6><strong>Descripción:</strong> @plan.Descripcion</h6>
                                            <p><strong>Fecha de Asignación:</strong> @plan.FechaAsignacion.ToString("dd/MM/yyyy")</p>
                                        </div>

                                        @if (plan.Alimentos != null && plan.Alimentos.Any())
                                        {
                                            var diasSemanaOrdenados = new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" };
                                            var alimentosPorDia = plan.Alimentos
                                            .GroupBy(a => a.DiaSemana)
                                            .OrderBy(g => Array.IndexOf(diasSemanaOrdenados, g.Key));

                                            foreach (var dia in alimentosPorDia)
                                            {
                                                <div class="mb-3">
                                                    <h6 class="text-primary">@dia.Key</h6>

                                                    @* Ordenar por hora dentro de cada día *@
                                                    @foreach (var comida in dia.OrderBy(c => c.HoraEstimada))
                                                    {
                                                        <div class="card mb-2 shadow-sm">
                                                            <div class="card-body">
                                                                <p><strong>Comida:</strong> @comida.Comida</p>
                                                                <p><strong>Hora Estimada:</strong> @(comida.HoraEstimada.HasValue? comida.HoraEstimada.Value.ToString(@"hh\:mm") : "-")</p>
                                                                <p><strong>Alimento:</strong> @comida.Alimento</p>
                                                                <p><strong>Porciones:</strong> @comida.Porciones</p>
                                                                @if (!string.IsNullOrEmpty(comida.Comentarios))
                                                                {
                                                                    <p><strong>Comentarios:</strong> @comida.Comentarios</p>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p class="text-muted">Este plan aún no tiene alimentos registrados.</p>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted">No hay planes nutricionales asignados para este cliente.</p>
                                    }
                                </div>
                            </div>
                        </div>

                        @* <h1>---------------------------------</h1>
                        <div>
                            <h3>Plan Nutricional</h3>
                            ViewBag.Plan = planNutricional;
                            ViewBag.Alimentos = planNutricional?.Alimentos.ToList();
                            @await Html.PartialAsync("~/Views/Shared/Partials/_AlimentosPlanNutricional.cshtml")
                        </div> *@

                    </div>
                </div>
            </div>

        </div>
    </div>

    @* Asistencia *@
    <div class="accordion" id="accordionAsistencia">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingAsistencia">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseAsistencia" aria-expanded="true" aria-controls="collapseAsistencia">
                    Registro de Asistencia
                </button>
            </h2>
            <div id="collapseAsistencia" class="accordion-collapse collapse " aria-labelledby="headingAsistencia" data-bs-parent="#accordionAsistencia">
                <div class="accordion-body">
                    @if (Model.Asistencias != null && Model.Asistencias.Any())
                    {
                        <div class="row">
                            <div class="card shadow p-4 mb-4">
                                <div class="table-responsive">
                                    <table class="table table-bordered table-hover table-striped">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>#</th>
                                                <th>Fecha de Ingreso</th>
                                                <th>Fecha de Salida</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.Asistencias)
                                            {
                                                <tr>
                                                    <td>@item.IdAsistencia</td>
                                                    <td>@item.FechaIngreso</td>
                                                    <td>@item.FechaSalida</td>
                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No hay Registrados de Asistencia.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Facturas *@
    <div class="accordion" id="accordionFacturas">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingFacturas">
                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseFacturas" aria-expanded="true" aria-controls="collapseFacturas">
                    Facturas Asociadas
                </button>
            </h2>
            <div id="collapseFacturas" class="accordion-collapse collapse " aria-labelledby="headingFacturas" data-bs-parent="#accordionFacturas">
                <div class="accordion-body">
                    <div class="row">
                        <!-- info aqui -->
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>  
    @functions {
    string ConvertToEmbed(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";

        if (url.Contains("youtube.com/watch?v="))
        {
            var videoId = url.Split("watch?v=")[1];
            return $"https://www.youtube.com/embed/{videoId}";
        }
        else if (url.Contains("youtube.com/shorts/"))
        {
            var videoId = url.Split("shorts/")[1].Split("?")[0];
            return $"https://www.youtube.com/embed/{videoId}";
        }

        return url;
    }
}

}
