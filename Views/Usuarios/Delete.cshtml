@model Tesina.Models.Usuarios

@{
    ViewData["Title"] = "Delete";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="text-center text-danger mb-4">¿Estás seguro de que deseas eliminar este cliente?</h2>

            <div class="card shadow-sm rounded-3">
                <div class="card-body">
                    <h4 class="mb-3 text-center">Cliente</h4>
                    <dl class="row">
                        <dt class="col-sm-4">Cédula</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Cedula)</dd>

                        <dt class="col-sm-4">Nombre Completo</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.NombreCompleto)</dd>

                        <dt class="col-sm-4">Fecha de Nacimiento</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaNacimiento)</dd>

                        <dt class="col-sm-4">Correo</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Correo)</dd>

                        <dt class="col-sm-4">Teléfono</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Telefono)</dd>

                        <dt class="col-sm-4">Dirección</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Direccion)</dd>

                        <dt class="col-sm-4">Fecha de Registro</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaRegistro)</dd>

                        <dt class="col-sm-4">Estado</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Estado)</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdUsuario" />
                <button type="submit" class="btn btn-danger me-2" onclick="return confirm('¿Estás seguro de que deseas eliminar este cliente?')" title="Eliminar">
                    Eliminar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>
