@model IEnumerable<Tesina.Models.Usuarios>

@{
    ViewData["Title"] = "Index";
}


<div class="container mt-5">
    <h2 class="text-center text-primary mb-4">
        <i class="bi bi-people-fill"></i> Lista de Clientes
    </h2>

    <div class="d-flex justify-content-end mb-3">
        <a class="btn btn-success" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Crear Nuevo Cliente
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover shadow-sm rounded">
                <thead class="table-dark">
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Cedula)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.NombreCompleto)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.FechaNacimiento)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Correo)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Telefono)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Direccion)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.FechaRegistro)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Estado)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Cedula</td>
                            <td>@item.NombreCompleto</td>
                            <td>@item.FechaNacimiento.ToShortDateString()</td>
                            <td>@item.Correo</td>
                            <td>@item.Telefono</td>
                            <td>@item.Direccion</td>
                            <td>@item.FechaRegistro.ToShortDateString()</td>
                            @if (@item.Estado)
                            {
                                <td>Activo</td>
                            }
                            else
                            {
                                <td>Inactivo</td>
                            }

                            <td class="text-center">
                                <a class="btn btn-sm btn-primary me-1" asp-action="Details" asp-route-id="@item.IdUsuario" title="Detalles">
                                    Ver<i class="bi bi-info-circle"></i>
                                </a>  <a class="btn btn-sm btn-info me-1" asp-action="Edit" asp-route-id="@item.IdUsuario" title="Editar">
                                    Modificar<i class="bi bi-pencil-square"></i>
                                </a>
                                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.IdUsuario">
                                    Eliminar<i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>

                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center mt-5">
            <i class="bi bi-exclamation-circle"></i> No hay clientes registrados.
        </div>
    }
</div>