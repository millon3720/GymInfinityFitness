<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProyectoDiseñoSistemas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ProyectoDiseñoSistemas.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/menu1.css" rel="stylesheet" />
    

</head>

<body>

    <header>
        @if (User.Identity.IsAuthenticated)
        {
            @if (User.HasClaim("Rol", "Entrenador"))
            {
                <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
                    <div class="container-fluid">
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                                aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownClientes" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-people-fill"></i> Clientes
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownClientes">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Usuarios" asp-action="Index">Lista de Clientes</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Usuarios" asp-action="Create">Agregar Cliente</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Expedientes" asp-action="Create"><i class="bi bi-bar-chart-fill"></i> Agregar Medidas Corporales</a>
                                        </li>
                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownEntrenadores" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-people-fill"></i> Entrenadores
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownEntrenadores">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Entrenadores" asp-action="Index">Lista de Entrenadores</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Entrenadores" asp-action="Create">Agregar Entrenador</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownRutinas" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi-clipboard-check"></i> Rutinas
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownRutinas">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Rutinas" asp-action="Index">Lista de Rutinas</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Rutinas" asp-action="Create">Agregar Rutina</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownEjercicios" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-barbell"></i> Ejercicios
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdownEjercicios">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Ejercicios" asp-action="Index">Lista de Ejercicios</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Ejercicios" asp-action="Create">Agregar Ejercicio</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownPlanNutricionales" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-clipboard-heart"></i> Plan Nutricional
                                    </a>
                                    <ul class=" dropdown-menu" aria-labelledby="navbarDropdownPlanNutricionales">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="PlanesNutricionales" asp-action="Index">Lista de Planes Nutricionales</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="PlanesNutricionales" asp-action="Create">Agregar Plan Nutricional</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownInventario" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-box-seam"></i> Control de Inventario
                                    </a>
                                    <ul class=" dropdown-menu" aria-labelledby="navbarDropdownInventario">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Inventarios" asp-action="Index">Lista Productos</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Inventarios" asp-action="Create">Agregar Producto</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownEventos" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-calendar-event"></i> Eventos
                                    </a>
                                    <ul class=" dropdown-menu" aria-labelledby="navbarDropdownEventos">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Eventos" asp-action="Index">Lista de Eventos</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Eventos" asp-action="Create">Agregar Evento</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-white" href="#" id="navbarDropdownFacturacion" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-receipt-cutoff"></i> Facturacion
                                    </a>
                                    <ul class=" dropdown-menu" aria-labelledby="navbarDropdownFacturacion">
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Facturas" asp-action="Index">Mostrar Facturas</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Facturas" asp-action="Create">Crear Nueva Factura</a>
                                        </li>

                                    </ul>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Asistencias" asp-action="RegistrarAsistencia"><i class="bi bi-clock-history"></i> Registro de Asistencia</a>
                                </li>
                            </ul>
                            <ul class="navbar-nav ml-auto">
                                
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Login" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Salir</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
            }
            @if (User.HasClaim("Rol", "Cliente"))
            {
                var idUsuario = Convert.ToInt32(User.FindFirst("IdUsuario")?.Value);

                <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
                    <div class="container-fluid">
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                                aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav flex-grow-1">
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Usuarios" asp-action="EditCliente" asp-route-id="@idUsuario"><i class="bi bi-people-fill"></i> Informacion Personal</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Expedientes" asp-action="MedidasCliente" asp-route-id="@idUsuario"><i class="bi bi-bar-chart-fill"></i> Medidas Corporales</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Lesiones" asp-action="LesionesCliente" asp-route-id="@idUsuario"> <i class="bi bi-clipboard-plus"></i> Mis Lesiones</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Rutinas" asp-action="RutinaCliente" asp-route-id="@idUsuario"><i class="bi-clipboard-check"></i> Mis Rutinas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="PlanesNutricionales" asp-action="PlanCliente" asp-route-id="@idUsuario"><i class="bi bi-clipboard-heart"></i> Planes Nutricionales</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Eventos" asp-action="EventoCliente" asp-route-id="@idUsuario"><i class="bi bi-calendar-event"></i> Proximos Eventos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Facturas" asp-action="FacturasCliente" asp-route-id="@idUsuario"><i class="bi bi-receipt-cutoff"></i> Mis Facturas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Usuarios" asp-action="AsistenciaCliente" asp-route-id="@idUsuario"><i class="bi bi-clock-history"></i> Mi Asistencia</a>
                                </li>
                            </ul>
                            <ul class="navbar-nav ml-auto">

                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Login" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Salir</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
            }

        }
    </header>
    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-light mt-4 bg-primary">
        <div class="container-fluid py-3">
            <div class="row text-center text-md-start">
                <!-- Columna izquierda: Dirección -->
                <div class="col-md-4 mb-3 mb-md-0">
                    <strong>Dirección:</strong><br />
                    Frente a Pali, Aguas Zarcas,<br />
                    San Carlos, Alajuela
                </div>

                <!-- Columna centro: Nombre -->
                <div class="col-md-4 mb-3 mb-md-0 d-flex flex-column align-items-center justify-content-center">
                    <strong>INFINITY FITNESS</strong><br />
                    &copy; 2025 - Todos los derechos reservados
                </div>

                <!-- Columna derecha: Contacto -->
                <div class="col-md-4 text-md-end">
                    <strong>Contacto:</strong><br />
                    📞 <a href="tel:+50684117404" class="text-light text-decoration-none">8411-7404</a> /
                    <a href="tel:+50671613145" class="text-light text-decoration-none">7161-3145</a><br />
                    📧 <a href="mailto:Kpaizv.0895@gmail.com" class="text-light text-decoration-none">Kpaizv.0895@gmail.com</a><br />
                </div>
            </div>
        </div>
    </footer>





    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>


</html>
