@model Tesina.Models.RutinaCreateViewModel
@{
    ViewData["Title"] = "Modificar Rutina";
    var ejerciciosList = ViewBag.ejerciciosList as SelectList;
}

<div class="container-fluid mt-4">
    <div class="card shadow rounded p-4 mb-4">
        <h4 class="text-primary text-center mb-4"><i class="bi-clipboard-check"></i> Modificar Rutina</h4>
        <div class="card shadow rounded p-4">

            <form asp-action="Edit" method="post">
                <input type="hidden" name="Rutina.IdRutina" value="@Model.Rutina.IdRutina" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input name="Rutina.Nombre" class="form-control" value="@Model.Rutina.Nombre" placeholder="Nombre de la Rutina" />
                    <span asp-validation-for="Rutina.Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <textarea name="Rutina.Descripcion" class="form-control" rows="3" placeholder="Descripción detallada">@Model.Rutina.Descripcion</textarea>
                    <span asp-validation-for="Rutina.Descripcion" class="text-danger"></span>
                </div>

                <div class="card shadow rounded p-4">

                    <h5 class="text-primary mb-3"> <i class="bi-clipboard-check"></i> Ejercicios de la Rutina</h5>
                <div id="ejerciciosContainer">
                    @for (int i = 0; i < Model.Ejercicios.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3 ejercicio-item bg-light">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label">Ejercicio</label>
                                    <select name="Ejercicios[@i].IdEjercicio" class="form-select">
                                        @foreach (var ejercicio in ViewBag.ejerciciosList as SelectList)
                                        {
                                            @if (ejercicio.Value == Model.Ejercicios[i].IdEjercicio.ToString())
                                            {
                                                <option value="@ejercicio.Value" selected>@ejercicio.Text</option>

                                            }
                                            else
                                            {
                                                <option value="@ejercicio.Value">@ejercicio.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Series</label>
                                    <input type="number" name="Ejercicios[@i].Series" class="form-control" value="@Model.Ejercicios[i].Series" />
                                    <span asp-validation-for="Ejercicios[@i].Series" class="text-danger"></span>

                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Repeticiones</label>
                                    <input type="number" name="Ejercicios[@i].Repeticiones" class="form-control" value="@Model.Ejercicios[i].Repeticiones" />
                                    <span asp-validation-for="Ejercicios[@i].Repeticiones" class="text-danger"></span>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Descanso (seg)</label>
                                    <input type="number" name="Ejercicios[@i].DescansoSegundos" class="form-control" value="@Model.Ejercicios[i].DescansoSegundos" />
                                    <span asp-validation-for="Ejercicios[@i].DescansoSegundos" class="text-danger"></span>

                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Día</label>

                                    <select name="Ejercicios[@i].DiaSemana" class="form-select">
                                        @foreach (var dia in ViewBag.DiasSemana as SelectList)
                                        {
                                            @if (dia.Text == Model.Ejercicios[i].DiaSemana.ToString())
                                            {
                                                <option value="@dia.Text" selected>@dia.Text</option>

                                            }
                                            else
                                            {
                                                <option value="@dia.Text">@dia.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-12 text-end">
                                    <button type="button" class="btn btn-danger btn-sm mt-2" onclick="this.closest('.ejercicio-item').remove()">Eliminar</button>
                                </div>
                            </div>
                        </div>
                    }

                    </div>               
                    <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-success mt-2" onclick="agregarEjercicio()"><i class="bi bi-plus-circle"></i> Agregar Ejercicio</button>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary shadow-sm">
                        <i class="bi bi-arrow-left-circle"></i> Volver a la lista
                    </a>
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let index = @Model.Ejercicios.Count;
        const ejercicios = @Html.Raw(Json.Serialize(ejerciciosList.Select(e => new { id = e.Value, nombre = e.Text })));

        function agregarEjercicio() {
            const container = document.getElementById("ejerciciosContainer");
            let opciones = '';
            ejercicios.forEach(e => {
                opciones += `<option value="${e.id}">${e.nombre}</option>`;
            });

            const dias = ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"];
            let diasOptions = '<option value="">Seleccione un día</option>';
            dias.forEach(d => diasOptions += `<option value="${d}">${d}</option>`);

            const div = document.createElement("div");
            div.classList.add("border", "rounded", "p-3", "mb-3", "ejercicio-item", "bg-light");

            div.innerHTML = `
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Ejercicio</label>
                        <select name="Ejercicios[${index}].IdEjercicio" class="form-select">
                            ${opciones}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Series</label>
                        <input type="number" name="Ejercicios[${index}].Series" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Repeticiones</label>
                        <input type="number" name="Ejercicios[${index}].Repeticiones" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Descanso (seg)</label>
                        <input type="number" name="Ejercicios[${index}].DescansoSegundos" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Día</label>
                        <select name="Ejercicios[${index}].DiaSemana" class="form-select">
                            ${diasOptions}
                        </select>
                    </div>
                    <div class="col-12 text-end">
                        <button type="button" class="btn btn-danger btn-sm mt-2" onclick="this.closest('.ejercicio-item').remove()">Eliminar</button>
                    </div>
                </div>
            `;
            container.appendChild(div);
            index++;
        }

        // Reindexar antes de enviar
                       document.querySelector("form").addEventListener("submit", function () {
            const items = document.querySelectorAll(".ejercicio-item");
            items.forEach((item, i) => {
                item.querySelectorAll("select, input").forEach(input => {
                    const name = input.getAttribute("name");
                    if (name) {
                        const newName = name.replace(/\[\d+\]/, `[${i}]`);
                        input.setAttribute("name", newName);
                    }
                });
            });
        });


    </script>
}

