@model WebApplication1.Models.RutinaCreateViewModel
@{
    ViewData["Title"] = "Crear Rutina";
}

<h2>Crear Rutina</h2>
<hr />

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Nombre de la Rutina</label>
        <input asp-for="Rutina.Nombre" class="form-control" />
    </div>

    <div class="form-group">
        <label>Descripción</label>
        <textarea asp-for="Rutina.Descripcion" class="form-control"></textarea>
    </div>

    <hr />
    <h4>Ejercicios de la Rutina</h4>
    <div id="ejerciciosContainer">
        <!-- Aquí se añadirán dinámicamente los ejercicios -->
    </div>

    <button type="button" class="btn btn-secondary mt-2" onclick="agregarEjercicio()">Agregar Ejercicio</button>

    <hr />
    <button type="submit" class="btn btn-primary mt-3">Guardar Rutina</button>
</form>

@section Scripts {
    <script>
        let index = 0;

        function agregarEjercicio() {
            const container = document.getElementById("ejerciciosContainer");

            const div = document.createElement("div");
            div.classList.add("border", "p-3", "mb-3", "ejercicio-item");

            div.innerHTML = `
                <div class="row align-items-end">
                    <div class="col-md-4">
                        <label>Ejercicio</label>
                        <select name="Ejercicios[${index}].IdEjercicio" class="form-control">
                            @foreach (var ej in ViewBag.Ejercicios as SelectList)
                            {
                                        <option value="@ej.Value">@ej.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Series</label>
                        <input type="number" name="Ejercicios[${index}].Series" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Repeticiones</label>
                        <input type="number" name="Ejercicios[${index}].Repeticiones" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Descanso (seg)</label>
                        <input type="number" name="Ejercicios[${index}].DescansoSegundos" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label>Día</label>
                            <select name="Ejercicios[${index}].DiaSemana" class="form-select">
                                <option value="">Seleccione un día</option>
                                <option value="Lunes">Lunes</option>
                                <option value="Martes">Martes</option>
                                <option value="Miércoles">Miércoles</option>
                                <option value="Jueves">Jueves</option>
                                <option value="Viernes">Viernes</option>
                                <option value="Sábado">Sábado</option>
                                <option value="Domingo">Domingo</option>
                            </select>
                    </div>
                    <div class="col-12 text-end mt-2">
                        <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('.ejercicio-item').remove()">Eliminar</button>
                    </div>
                </div>
            `;

            container.appendChild(div);
            index++;
        }
    </script>
}

