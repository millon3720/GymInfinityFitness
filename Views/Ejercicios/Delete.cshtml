@model Tesina.Models.Ejercicio

@{
    ViewData["Title"] = "Delete";
}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h2 class="text-center text-danger mb-4">¿Estás seguro de que deseas eliminar este ejercicio?</h2>

            <div class="card shadow-sm rounded-3">
                <div class="card-body">
                    <h4 class="mb-3 text-center">Ejercicio</h4>
                    <dl class="row">
                        <dt class="col-sm-4">Nombre</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Nombre)</dd>

                        <dt class="col-sm-4">Descripción</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Descripcion)</dd>

                        <dt class="col-sm-4">Video URL</dt>
                        <dd class="col-sm-8">
                            <a href="@Model.VideoURL" target="_blank">@Model.VideoURL</a>
                        </dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" class="mt-4 text-center">
                <input type="hidden" asp-for="IdEjercicio" />
                <button type="submit" class="btn btn-danger me-2" onclick="return confirm('¿Estás seguro de que deseas eliminar este ejercicio?')" title="Eliminar">
                    Eliminar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>
