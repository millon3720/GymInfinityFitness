@model Tesina.Models.Expediente

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-4">
    <h2 class="text-danger">Eliminar Expediente</h2>
    <hr />
    <h5 class="text-warning">¿Está seguro de que desea eliminar este expediente?</h5>

    <div class="card border-danger shadow-sm mt-4">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Cédula Cliente</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Usuario.Cedula)</dd>

                <dt class="col-sm-3">Fecha Registro</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.FechaRegistro)</dd>

                <dt class="col-sm-3">Peso (Kg)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PesoKg)</dd>

                <dt class="col-sm-3">Altura (cm)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.AlturaCm)</dd>

                <dt class="col-sm-3">IMC</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.IMC)</dd>

                <dt class="col-sm-3">Porcentaje de Grasa</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PorcentajeGrasa)</dd>

                <dt class="col-sm-3">Porcentaje Muscular</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PorcentajeMuscular)</dd>

                <dt class="col-sm-3">Medida Pecho</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MedidaPecho)</dd>

                <dt class="col-sm-3">Medida Espalda</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MedidaEspalda)</dd>

                <dt class="col-sm-3">Medida Cintura</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MedidaCintura)</dd>

                <dt class="col-sm-3">Medida Cadera</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MedidaCadera)</dd>

                <dt class="col-sm-3">Bíceps Derecho</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.BicepDerecho)</dd>

                <dt class="col-sm-3">Bíceps Izquierdo</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.BicepIzquierdo)</dd>

                <dt class="col-sm-3">Pierna Derecha</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PiernaDerecha)</dd>

                <dt class="col-sm-3">Pierna Izquierda</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PiernaIzquierda)</dd>

                <dt class="col-sm-3">Pantorrilla Derecha</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PantorrillaDerecha)</dd>

                <dt class="col-sm-3">Pantorrilla Izquierda</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.PantorrillaIzquierda)</dd>

                <dt class="col-sm-3">Observaciones</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Observaciones)</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdExpediente" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Eliminar
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle"></i> Cancelar
            </a>
        </div>
    </form>
</div>
